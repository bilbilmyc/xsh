{
  "name": "xsh",
  "private": true,
  "version": "0.1.7",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11.10.0"
  },
  "scripts": {
    "dev": "pnpm --filter desktop exec tauri dev",
    "build": "pnpm --filter desktop run build",
    "tauri:build": "pnpm --filter desktop exec tauri build",
    "check": "pnpm run build && cargo test --workspace",
    "build:macos:personal": "bash scripts/build-macos-personal.sh",
    "build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1"
  }
}
